<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.imsg-forwarder</string>

  <!-- Path to the installed binary -->
  <key>ProgramArguments</key>
  <array>
    <string>/usr/local/bin/imsg-forwarder</string>
  </array>

  <!-- Start automatically on login -->
  <key>RunAtLoad</key>
  <true/>

  <!-- Restart automatically on crash -->
  <key>KeepAlive</key>
  <true/>

  <!-- Throttle restart interval in seconds -->
  <key>ThrottleInterval</key>
  <integer>30</integer>

  <key>StandardOutPath</key>
  <string>/Users/YOUR_USERNAME/Library/Logs/imsg-forwarder.log</string>

  <key>StandardErrorPath</key>
  <string>/Users/YOUR_USERNAME/Library/Logs/imsg-forwarder.error.log</string>
</dict>
</plist>
