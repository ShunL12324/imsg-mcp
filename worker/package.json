{
  "name": "imsg-forwarder-worker",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create imsg-forwarder",
    "db:migrate": "wrangler d1 execute imsg-forwarder --file=../schema.sql",
    "db:migrate:remote": "wrangler d1 execute imsg-forwarder --remote --file=../schema.sql",
    "secret": "wrangler secret put API_TOKEN"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240909.0",
    "typescript": "^5.5.2",
    "wrangler": "^3.78.7"
  }
}
